{
  "identifier": "main-capability",
  "description": "Full access for the main application window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:window:default",
    "global-shortcut:default",
    "dialog:default",
    {
      "identifier": "fs:default",
      "allow": [{ "path": "$APPDATA/**" }]
    }
  ]
}
